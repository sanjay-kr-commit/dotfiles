" https://wiki.archlinux.org/index.php\?limit\=1000000\&search\=$query) && if [[ $redirectedPage =~ ".*/title/.*" ]] ; then cat /dev/shm/content | html2text | nvim ; else cat /dev/shm/content | html2text | grep -o "\* *\[.*\] *(.*)" | grep -o "(.*)" | sed -e "s#(/#https://wiki.archlinux.org/#" -e "s/[()]//g" | grep -o "https[^ ]*" | fzf | xargs -I {} curl {} 2>/dev/null | html2text >/dev/shm/content && nvim /dev/shm/content ; fi && unset redirectedPage && unset query && rm /dev/shm/content'
